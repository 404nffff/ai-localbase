# Docker Compose 环境变量示例
# 复制为 .env 后可直接用于 docker compose 启动

# 应用访问令牌，前端与 MCP 客户端请求后端时需要携带 Bearer Token
APP_AUTH_TOKEN=change-me-app-token

# Docker Compose 宿主机端口映射
PORT_BIND_HOST=127.0.0.1
BACKEND_PORT=8080
FRONTEND_PORT=4173
OLLAMA_PORT=11434
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# 单个服务端口绑定地址，留空时继承 PORT_BIND_HOST
BACKEND_BIND_HOST=
FRONTEND_BIND_HOST=
OLLAMA_BIND_HOST=
QDRANT_HTTP_BIND_HOST=
QDRANT_GRPC_BIND_HOST=

# Ollama 服务地址；Docker Desktop 场景可直接使用 host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434

# 向量维度，必须与当前 Embedding 模型输出维度一致
QDRANT_VECTOR_SIZE=768

# Qdrant 请求超时秒数
QDRANT_TIMEOUT_SECONDS=5

# Qdrant API Key，可留空
QDRANT_API_KEY=
